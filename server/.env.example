DATABASE_URL=your-neon-connection-string-here
JWT_SECRET=your-secret-here
PORT=3001
# Shared DK Plus API token for the company — returned to all users on login
DK_TOKEN=your-dk-token-here
# Gmail credentials for transactional email (invite emails etc.)
GMAIL_USER=your-gmail-address-here
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# Duo Admin API credentials (https://admin.duosecurity.com → Applications → Protect an Application → Admin API)
DUO_IKEY=your-duo-admin-integration-key
DUO_SKEY=your-duo-admin-secret-key
DUO_API_HOST=api-xxxxxxxx.duosecurity.com
