VITE_API_BASE_URL=https://api.dkplus.is/api/v1
VITE_MOCK_API_URL=http://localhost:3001
VITE_API_TOKEN=your-bearer-token-here
VITE_APP_ENV=development

# Auðkenni REST API (test environment, api_v203)
# In development, use the Vite proxy path so session cookies work (see vite.config.ts).
# In production, point this at a backend proxy that forwards to the real Auðkenni URL.
VITE_AUDKENNI_BASE_URL=/audkenni/
VITE_AUDKENNI_CLIENT_ID=dkApiTest
# WARNING: keep the secret out of version control — use a backend proxy in production
VITE_AUDKENNI_CLIENT_SECRET=your_client_secret_here
VITE_AUDKENNI_REDIRECT_URI=http://localhost:3000/callback

# Zoho Desk Knowledge Base API (OAuth2, EU data center)
# 1. Find Org ID: Zoho Desk → Settings → General → Company Details
# 2. Generate refresh token: see src/features/knowledgeBase/api/zoho.auth.ts header
# WARNING: VITE_* vars are bundled into the client — acceptable for this internal portal
VITE_ZOHO_CLIENT_ID=your_zoho_client_id
VITE_ZOHO_CLIENT_SECRET=your_zoho_client_secret
VITE_ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
VITE_ZOHO_ORG_ID=your_zoho_org_id

# YouTube Data API v3
# 1. Enable YouTube Data API v3 in Google Cloud Console
# 2. Create an API key and restrict it to YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key
VITE_YOUTUBE_CHANNEL_ID=your_youtube_channel_id


